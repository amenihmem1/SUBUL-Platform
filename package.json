{
  "name": "subul-platform",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:frontend",
    "dev:all": "node scripts/run-dev-all.js",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:postgres": "docker-compose up -d postgres",
    "dev:agents": "cd backend && docker-compose -f docker-compose.agents.yml --profile dev up -d",
    "verify:deploy": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify-production-deploy.ps1"
  },
  "dependencies": {
    "@nestjs/config": "^4.0.3",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/typeorm": "^11.0.0",
    "@types/next": "^9.0.0",
    "@types/react": "^19.1.8",
    "google-translate-api-browser": "^5.0.0",
    "jwks-rsa": "^3.2.2",
    "lucide-react": "^0.524.0",
    "next": "^16.2.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.18.0",
    "react": "^19.1.0",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@types/passport-jwt": "^4.0.1"
  },
  "overrides": {
    "lodash": "4.18.1",
    "path-to-regexp": "8.4.2",
    "picomatch": "4.0.4"
  }
