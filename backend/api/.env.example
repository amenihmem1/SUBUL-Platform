# Subul Platform Configuration

# Database configuration (NestJS backend)
DB_HOST=localhost
DB_PORT=5434
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=shared_db
# Aurora / Azure PostgreSQL: set true so migrations (data-source.ts) and API use TLS
DB_SSL=false

DATABASE_URL=postgresql://postgres:postgres@localhost:5434/shared_db

# API Configuration
PORT=3001
NODE_ENV=development
DEBUG=true

# JWT Configuration (CRITICAL: use a long random secret in production; min 16 chars)
JWT_SECRET=dev-only-change-in-production-min-16-chars
JWT_EXPIRES_IN=24h

# Session cookie signing secret (min 16 chars in production)
SESSION_SECRET=subul-dev-session-secret-change-in-production

# --- Email: Amazon SES SMTP (nodemailer) ---
SMTP_HOST=email-smtp.eu-central-1.amazonaws.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=subul@smartovate.com
MAIL_FROM_NAME=Subul Platform

# NestJS -> Python agents (CV boost, roadmap, job-search, etc.). Default 4000000 ms (~66 min, AWS ALB max idle timeout).
AGENT_HTTP_TIMEOUT_MS=4000000

# Frontend Configuration
FRONTEND_URL=http://localhost:3000
# Optional: extra browser origins for CORS (comma-separated). FRONTEND_URL origin + www/app variants are included automatically.
# Production example: CORS_ORIGINS=https://subul.uk,https://www.subul.uk,https://app.subul.uk
# CORS_ORIGINS=
# Optional: log slugs returned by GET /api/public/plans (true/false)
# LOG_PUBLIC_PLANS=false
# Locale segment in verification links: /{EMAIL_VERIFICATION_LOCALE}/auth/verify-email?token=
EMAIL_VERIFICATION_LOCALE=en
# Production API: https://app.subul.uk/api
BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# ===================================
# STRIPE CONFIGURATION (International)
# ===================================
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STANDARD_MONTHLY=price_...
STRIPE_PRICE_STANDARD_QUARTERLY=price_...
STRIPE_PRICE_STANDARD_ANNUAL=price_...
STRIPE_PRICE_BASIC_FREE=price_...

# ===================================
# FLOUCI CONFIGURATION (Tunisia)
# ===================================
FLOUCI_PUBLIC_TOKEN=your-flouci-public-token
FLOUCI_PRIVATE_TOKEN=your-flouci-private-token
FLOUCI_API_URL=https://developers.flouci.com/api/v2
# Prices in TND (converted to millimes internally: 49.99 TND → 49990 millimes)
FLOUCI_PRICE_STANDARD_MONTHLY=49.99
FLOUCI_PRICE_STANDARD_QUARTERLY=149.97
FLOUCI_PRICE_STANDARD_ANNUAL=599.88

# ===================================
# PROXY / VPN DETECTION
# ===================================
PROXYCHECK_API_KEY=your-proxycheck-api-key
# Dev testing only: force pricing region (TN | US | EU). Leave empty in production.
GEO_DEV_FORCE_REGION=

# ===================================
# AWS S3 (proof-of-payment uploads)
# ===================================
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
PROOF_BUCKET=your-s3-bucket-name

LEARNER_EMPLOI_V2_ENABLED=true

# Seeding/import defaults: keep disabled unless explicitly requested.
RUN_SEED_ON_BOOT=false
SEED_PROFILE=none
SEED_LEGACY_CATALOG=false

# Certification academy pack (see seed/subul-certification-pack and seed/CERTIFICATION_PACK_VERIFICATION.md)
# Preferred workflow: run npm run import:certification-pack manually.
AUTO_SEED_CERTIFICATION_PACK=false
CONTENT_PACK_IMPORT_ON_START=false
# CLI-only override for explicit import command
FORCE_CERT_PACK_IMPORT=0
REQUIRE_CONTENT_INDEXING=false
CERTIFICATION_PACK_DIR=seed/subul-certification-pack

# Set to true on every production deploy to sync subscription plan prices from code → DB.
# Leave false (or unset) on normal restarts to preserve admin dashboard price edits.
FORCE_PLAN_SEED=false
