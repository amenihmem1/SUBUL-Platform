{
  "name": "nestjs-api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "node scripts/sync-certificate-template.mjs",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "migration:generate": "npm run build && typeorm migration:generate src/migrations/migration --dataSource dist/data-source.js",
    "migration:run": "typeorm migration:run --dataSource dist/data-source.js",
    "migration:revert": "typeorm migration:revert --dataSource dist/data-source.js",
    "seed": "npm run seed:baseline",
    "seed:run": "node dist/seed/run-seed.js",
    "seed:labs": "node dist/seed/seed-labs-only.js",
    "seed:cert-pack": "nest build && node dist/seed/seed-certification-pack.js",
    "import:certification-pack": "cross-env FORCE_CERT_PACK_IMPORT=1 node dist/seed/seed-certification-pack.js",
    "import:certification-pack:build": "nest build && npm run import:certification-pack",
    "bootstrap:prod": "npm run migration:run && npm run seed:run && node dist/seed/seed-certification-pack.js && node dist/main.js",
    "seed:baseline": "nest build && cross-env SEED_PROFILE=baseline node dist/seed/run-seed.js",
    "seed:demo": "nest build && cross-env SEED_PROFILE=demo node dist/seed/run-seed.js",
    "seed:none": "nest build && cross-env SEED_PROFILE=none node dist/seed/run-seed.js",
    "seed:commercial": "npx ts-node src/seed-sample.ts",
    "seed:sample": "npx ts-node src/seed-sample.ts",
    "smoke-test": "powershell -ExecutionPolicy Bypass -File ../../scripts/smoke-test-api.ps1",
    "test:smtp": "node scripts/ses-smtp-test.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.995.0",
    "@aws-sdk/s3-request-presigner": "^3.1027.0",
    "@azure/msal-node": "^5.2.2",
    "@azure/storage-blob": "^12.31.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.17",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.17",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@willsoto/nestjs-prometheus": "^6.1.0",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "cheerio": "^1.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cookie-parser": "^1.4.7",
    "form-data": "^4.0.5",
    "ioredis": "^5.10.1",
    "joi": "^18.1.2",
    "mammoth": "^1.12.0",
    "nodemailer": "^8.0.4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.18.0",
    "prom-client": "^15.1.3",
    "puppeteer": "^24.42.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "stripe": "^21.0.1",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^6.4.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.2",
    "@types/yargs": "^17.0.35",
    "cross-env": "^10.1.0",
    "dotenv": "^16.4.5",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "overrides": {
    "lodash": "4.18.1",
    "path-to-regexp": "8.4.2",
    "picomatch": "4.0.4"
  }
}
