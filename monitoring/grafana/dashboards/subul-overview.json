{
  "title": "Subul — Platform Overview",
  "uid": "subul-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["subul", "overview"],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Services UP",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "count(probe_success == 1)",
          "legendFormat": "UP"
        }
      ],
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Services DOWN",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "count(probe_success == 0) or vector(0)",
          "legendFormat": "DOWN"
        }
      ],
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "AI Cost Today (USD)",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(increase(azure_openai_cost_usd_total[24h])) + sum(increase(deepgram_cost_usd_total[24h])) + sum(increase(cartesia_cost_usd_total[24h])) + sum(increase(azure_search_cost_usd_total[24h]))",
          "legendFormat": "Cost"
        }
      ],
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 25 },
              { "color": "red", "value": 50 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "API Requests (5m)",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(agent_proxy_requests_total[5m])) * 300",
          "legendFormat": "Requests"
        }
      ],
      "options": {
        "colorMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Active Alerts",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "count(ALERTS{alertstate=\"firing\"}) or vector(0)",
          "legendFormat": "Firing"
        }
      ],
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 6,
      "type": "table",
      "title": "Service Health",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 10 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "probe_success",
          "instant": true,
          "legendFormat": "{{instance}}",
          "refId": "A"
        },
        {
          "expr": "probe_duration_seconds",
          "instant": true,
          "legendFormat": "{{instance}}",
          "refId": "B"
        }
      ],
      "options": {
        "sortBy": [{ "displayName": "Value #A", "desc": false }]
      },
      "fieldConfig": {
        "defaults": { "custom": { "filterable": true } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value #A" },
            "properties": [
              { "id": "displayName", "value": "Status" },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
                ]
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #B" },
            "properties": [
              { "id": "displayName", "value": "Latency" },
              { "id": "unit", "value": "s" },
              { "id": "decimals", "value": 3 }
            ]
          }
        ]
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "API Request Rate (all agents)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 10 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by(agent) (rate(azure_openai_requests_total[5m]))",
          "legendFormat": "{{agent}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Probe Latency P95 (ms)",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "probe_duration_seconds * 1000",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 1, "fillOpacity": 5 }
        }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "AI Cost Rate (USD/hr)",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(azure_openai_cost_usd_total[5m])) * 3600",
          "legendFormat": "OpenAI"
        },
        {
          "expr": "sum(rate(deepgram_cost_usd_total[5m])) * 3600",
          "legendFormat": "Deepgram"
        },
        {
          "expr": "sum(rate(cartesia_cost_usd_total[5m])) * 3600",
          "legendFormat": "Cartesia"
        },
        {
          "expr": "sum(rate(azure_search_cost_usd_total[5m])) * 3600",
          "legendFormat": "Azure Search"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "stacking": { "mode": "normal" } }
        }
      }
    }
  ]
}
