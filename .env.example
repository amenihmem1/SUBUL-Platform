# ─── Quick start ───────────────────────────────────────────────────────
# 1. cp .env.example .env        (then fill in secrets below)
# 2. docker compose up -d        (starts postgres, api, frontend)
# 3. Open http://localhost:3000
# ───────────────────────────────────────────────────────────────────────

# Database (NestJS + optional Job Search agent)
DB_HOST=localhost
DB_PORT=5434
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=shared_db

# NestJS API
NODE_ENV=development
PORT=3001
# Optional: certification academy JSON pack import on API container boot (docker compose)
# AUTO_SEED_CERTIFICATION_PACK=true
# REQUIRE_CONTENT_INDEXING=false
# CERTIFICATION_PACK_DIR=seed/subul-certification-pack

# JWT (CHANGE in production)
JWT_SECRET=subul-platform-super-secret-jwt-key
JWT_EXPIRES_IN=24h
SESSION_SECRET=subul-dev-session-secret-change-in-production

# Frontend (for auth redirects)
FRONTEND_URL=http://localhost:3000

# Agent base URLs — NestJS proxies all traffic; set in production or when agents run elsewhere
# In Docker, the API uses service names (see docker-compose.yml). For local dev, fallbacks apply.
QUIZ_AGENT_URL=http://localhost:8001
ROADMAP_AGENT_URL=http://localhost:8002
CV_BOOSTER_URL=http://localhost:8005
JOB_SEARCH_AGENT_URL=http://localhost:8006
COACH_AGENT_URL=http://localhost:8004
CLOUD_TUTOR_AGENT_URL=http://localhost:8000

# HTTP timeout (ms) for NestJS -> Python agent calls (CV boost, roadmap, quiz, job-search, coach, cloud-tutor). Default 4000000 (~66 min, matches AWS ALB max idle timeout).
AGENT_HTTP_TIMEOUT_MS=4000000

# Next.js (frontend) — only backend URL needed; no direct agent URLs
# Production: https://app.subul.uk/api
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_HR_COACH_URL=http://localhost:8080
# Browser -> Nest timeout for agent-proxied routes (/api/cv, /api/roadmap, /api/quiz, etc.). Should be >= AGENT_HTTP_TIMEOUT_MS.
NEXT_PUBLIC_AGENT_API_TIMEOUT_MS=4000000
NEXT_PUBLIC_API_URL=http://localhost:3001

# Voice synthesis APIs
# Browser (course/lab narration): Next.js inlines NEXT_PUBLIC_* — see frontend/next.config.ts
# You may set only CARTESIA_API_KEY / DEEPGRAM_API_KEY here; they are mapped to NEXT_PUBLIC_* for the client.
NEXT_PUBLIC_CARTESIA_API_KEY=your_cartesia_api_key_here
NEXT_PUBLIC_DEEPGRAM_API_KEY=your_deepgram_api_key_here
CARTESIA_API_KEY=your_cartesia_api_key_here
DEEPGRAM_API_KEY=your_deepgram_api_key_here
# Coach agent TTS (server-side; docker-compose api / agent-coach) — can match CARTESIA_API_KEY

# Transactional email: Amazon SES SMTP (see backend/api/.env.example)
SMTP_HOST=email-smtp.eu-central-1.amazonaws.com
SMTP_PORT=587
SMTP_SECURE=false

SMTP_USER=AKIAQGYBPWCVOPRWKHGY
SMTP_PASS=BCW/znEeRS0SAmdsyGDPHhj4c1PoXD6JJ1u7lE+lqJN/

MAIL_FROM=subul@smartovate.com
MAIL_FROM_NAME="Subul Platform"
EMAIL_VERIFICATION_LOCALE=en

# Job Search Smart-ATS: uses AZURE_OPENAI_* from backend/agents/JobSearch-SUBUL/.env.txt (structure_cv / structure_jd per scan).

# Add Auth0, Azure OpenAI, Cosmos, etc. from your .env as required by each service.

# ===================================
# Monitoring (Grafana / Prometheus)
# ===================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-in-production
GRAFANA_ROOT_URL=https://monitoring.subul.uk

# Alert destination — Alertmanager forwards critical/warning alerts here
ADMIN_ALERT_EMAIL=admin@subul.io

# Cost alert thresholds (USD) — edit alerts.yml and reload Prometheus after changing
AI_DAILY_COST_ALERT_THRESHOLD_USD=50
AI_MONTHLY_COST_ALERT_THRESHOLD_USD=1000

# Provider cost rates (USD) — used by shared/metrics.py to estimate spend in counters
# Azure OpenAI (per 1K tokens)
COST_AZURE_GPT4O_INPUT_PER_1K=0.005
COST_AZURE_GPT4O_OUTPUT_PER_1K=0.015
COST_AZURE_EMBED_PER_1K=0.0001
# Deepgram STT (per minute of audio)
COST_DEEPGRAM_PER_MINUTE=0.0059
# Cartesia TTS (per 1,000 characters)
COST_CARTESIA_PER_1K_CHARS=0.0015
# Azure Cognitive Search (per 1K queries — S1 tier estimate)
COST_AZURE_SEARCH_PER_1K_QUERIES=0.025
